# ── BabelCast Subtitle — LAZY-LOAD variant ──────────────────────────────────
# Same as Dockerfile but WITHOUT the GGUF/Whisper pre-bake.
#
# Models are downloaded at server startup via:
#   - hf_hub_download() for the GGUF      (server.py:_load_llm)
#   - WhisperModel(..., download_root)    (server.py:_load_stt, faster_whisper)
#
# Both download paths use the standard HF cache, so they benefit from the
# hf-xet HIGH_PERFORMANCE + FIXED_DOWNLOAD_CONCURRENCY=50 env vars below
# (validated on Vast.ai RTX 4090: 394 MB/s for GGUF — see CLAUDE.md).
#
# Why a separate Dockerfile and not a build-arg?
#   The bake step is cache-invalidating no matter what, so a build-arg
#   conditional saves no GHA cache. A separate file is just simpler to
#   reason about and lets the workflow build both variants in parallel
#   without ARG plumbing.
#
# Expected size:
#   :latest  ≈ 14 GB compressed (GGUF + Whisper pre-baked, ~8 GB of weights)
#   :lazy    ≈  6 GB compressed (no weights — downloaded at boot)
#
# Trade-off:
#   :latest — slower image pull, faster first request after pull
#   :lazy   — faster image pull, ~21s of HF download before first request
#             (4 GB GGUF + 3 GB Whisper @ 350 MB/s validated on Vast.ai US)
# ─────────────────────────────────────────────────────────────────────────────

ARG BASE_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    COMPUTE_TYPE=float16 \
    LLM_REPO=bullerwins/translategemma-4b-it-GGUF \
    LLM_FILENAME=translategemma-4b-it-Q8_0.gguf \
    N_CTX=1024 \
    N_BATCH=1024 \
    N_UBATCH=512 \
    FLASH_ATTN=true

# System deps — minimal for inference only
# aria2 + zstd: kept for the hf-download fallback helper, even though hf-xet
# wins on Vast.ai (see CLAUDE.md model download bench)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev python3-pip \
    ffmpeg libsndfile1 curl aria2 zstd && \
    ln -sf /usr/bin/python3.11 /usr/bin/python3 && \
    rm -rf /var/lib/apt/lists/*

# Install hf-download helper (aria2c-based, with HF Hub fallback)
COPY hf-download /usr/local/bin/hf-download
RUN chmod +x /usr/local/bin/hf-download

WORKDIR /app

# Step 1: PyTorch from CUDA 12.8 index
ARG CUDA_INDEX=https://download.pytorch.org/whl/cu128
RUN pip install --no-cache-dir torch==2.11.0 --index-url ${CUDA_INDEX}

# Step 2: llama-cpp-python — download pre-built cu124 wheel directly (no compilation).
# cu124 wheel is forward-compatible with CUDA 12.8 runtime (NVIDIA minor version compat).
ARG LLAMA_CPP_VERSION=0.3.19
RUN curl -L -o /tmp/llama_cpp_python-${LLAMA_CPP_VERSION}-cp311-cp311-linux_x86_64.whl \
    "https://github.com/abetlen/llama-cpp-python/releases/download/v${LLAMA_CPP_VERSION}-cu124/llama_cpp_python-${LLAMA_CPP_VERSION}-cp311-cp311-linux_x86_64.whl" && \
    pip install --no-cache-dir "/tmp/llama_cpp_python-${LLAMA_CPP_VERSION}-cp311-cp311-linux_x86_64.whl[server]" && \
    rm /tmp/llama_cpp_python-*.whl

# Step 3: Everything else from PyPI
RUN pip install --no-cache-dir \
    "faster-whisper>=1.2.1" \
    "ctranslate2>=4.7.1" \
    httpx \
    "huggingface-hub>=1.0.0" \
    "hf_xet>=1.4.0" \
    python-multipart \
    uvicorn[standard] \
    fastapi

# Download tuning: hf-xet with HIGH_PERFORMANCE + pinned concurrency.
# These env vars are CRITICAL for the lazy variant — they govern the runtime
# download speed of the GGUF and Whisper. server.py also does setdefault() on
# them as a safety net for non-Docker runs.
ENV HF_HOME=/app/.cache/huggingface \
    HUGGINGFACE_HUB_CACHE=/app/.cache/huggingface/hub \
    HF_XET_HIGH_PERFORMANCE=1 \
    HF_XET_FIXED_DOWNLOAD_CONCURRENCY=50

# ── No model pre-bake here. ────────────────────────────────────────────────
# The :latest variant pre-downloads the GGUF and Whisper here to eliminate
# runtime download. The :lazy variant intentionally skips this so the image
# stays small (~6 GB instead of ~14 GB) and the models stream from HF on
# first server startup. server.py:_load_llm/_load_stt handle this transparently.
# ───────────────────────────────────────────────────────────────────────────

COPY server.py .
COPY idle_watchdog.py .
COPY start.sh .
RUN chmod +x start.sh

EXPOSE 8000

# Note: longer start-period than :latest because runtime download adds ~21s
HEALTHCHECK --interval=10s --timeout=5s --start-period=180s --retries=3 \
    CMD curl -sf http://localhost:8000/health || exit 1

CMD ["/app/start.sh"]
