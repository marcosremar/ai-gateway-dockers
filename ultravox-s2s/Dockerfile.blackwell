# Ultravox Speech-to-Speech — Blackwell GPU image (RTX 5090/5080)
#
# Base: nvidia/cuda:12.8.1 (native Blackwell support, driver 570+)
# Models pre-downloaded at build time (~17GB) for instant boot.
# ENTRYPOINT reset for Vast.ai compatibility

FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

ENTRYPOINT []

ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1 DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# ── Python 3.11 + system deps ──
# aria2 + zstd: multi-connection downloads (~30% faster than curl/single-stream)
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-dev python3.11-venv python3-pip \
    ffmpeg libsndfile1 sox libsox-dev curl aria2 zstd \
    libgomp1 libsndfile1-dev \
    && ln -sf /usr/bin/python3.11 /usr/local/bin/python3 \
    && ln -sf /usr/bin/python3.11 /usr/local/bin/python \
    && python3 -m pip install --no-cache-dir --upgrade pip \
    && rm -rf /var/lib/apt/lists/*

# Install hf-download helper (aria2c-based, with HF Hub fallback)
COPY hf-download /usr/local/bin/hf-download
RUN chmod +x /usr/local/bin/hf-download

# ── PyTorch (CUDA 12.8 — native Blackwell) ──
RUN pip3 install --no-cache-dir torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu128

# ── Ultravox deps ──
RUN pip install --no-cache-dir \
    "transformers>=4.45.0" "accelerate>=1.12.0" \
    peft librosa soundfile numpy scipy

# ── Web framework ──
# hf_xet replaces the deprecated hf_transfer for HF Hub downloads; see the
# HF_XET_HIGH_PERFORMANCE + HF_XET_FIXED_DOWNLOAD_CONCURRENCY env vars below
# for the tuning. Benchmark on Vast.ai RTX 4090 (2026-04-07): +24% vs legacy.
RUN pip install --no-cache-dir \
    "fastapi>=0.115.0" "uvicorn[standard]>=0.32.0" \
    python-multipart httpx websockets \
    "huggingface-hub>=1.0.0" "hf_xet>=1.4.0" \
    "pydantic-settings>=2.0" \
    "aiortc>=1.9.0" av

# ── Qwen3-TTS ──
RUN pip install --no-cache-dir einops onnxruntime sox && \
    pip install --no-cache-dir "faster-qwen3-tts>=0.2.4"

RUN rm -rf /root/.cache/pip /tmp/pip-*

ENV HF_HOME=/app/.cache/huggingface \
    HUGGINGFACE_HUB_CACHE=/app/.cache/huggingface/hub \
    HF_XET_HIGH_PERFORMANCE=1 \
    HF_XET_FIXED_DOWNLOAD_CONCURRENCY=50 \
    TORCHINDUCTOR_CACHE_DIR=/workspace/.torch-cache \
    TORCHINDUCTOR_FX_GRAPH_CACHE=1 \
    TORCHINDUCTOR_AUTOGRAD_CACHE=1

# ── Pre-download models at build time ──
# This avoids 16GB+ downloads at runtime (which cause OOM kills on Vast.ai).
# HF_TOKEN is needed for gated Llama-3.1-8B (used inside Ultravox).
ARG HF_TOKEN
COPY download_models.py /tmp/download_models.py
RUN mkdir -p /app/.cache/huggingface && \
    HF_TOKEN=${HF_TOKEN} python3 /tmp/download_models.py

COPY download_models.py /app/download_models.py
COPY api/ /app/api/
COPY start.sh /app/start.sh
# Marker: tells start.sh to skip pip install (everything pre-installed in this image)
RUN touch /app/.prebuilt && \
    chmod +x /app/start.sh && chmod -R 777 /app/.cache 2>/dev/null || true

EXPOSE 8000

# No HEALTHCHECK — Vast.ai destroys instances when healthcheck fails during
# model loading. The /health endpoint is still available for external monitoring.

CMD ["/app/start.sh"]
